NAME 	= push_swap.a
CC 		= cc
FLAGS 	= -Wall -Wextra -Werror
SRCS 	=	srcs/main.c \
			srcs/stack_utils.c \
			...

OBJ 	= $(SRC:.c=.o)
LIBFT	= Libft/libft.a

all: $(LIBFT) $(NAME)

$(LIBFT):
	make -C Libft

$(NAME): $(OBJ)
	$(CC) $(FLAGS) $(OBJ) $(LIBFT) -o $(NAME)

%.o:

clean :
	make clean -C Libft
	$(RM) $(OBJ)

fclean: clean
	make fclean -C Libft
	$(RM) $(NAME)

re: fclean all

.PHONY: all clean re fclean 